<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ITnews</title>
  <style>
    :root {
      --bg: #0D0D0D;
      --bg-card: #161616;
      --bg-card-hover: #1E1E1E;
      --text: #E8E6E0;
      --text-muted: #6B6B6B;
      --text-dim: #3A3A3A;
      --accent-green: #4ADE80;
      --accent-purple: #818CF8;
      --border: #222222;
      --border-hover: #333333;
      --source-hatena: #00A4DE;
      --source-hn: #FF6600;
      --source-reddit: #FF4500;
      --font-mono: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', ui-monospace, monospace;
      --font-sans: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Yu Gothic UI', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg); color: var(--text);
      font-family: var(--font-sans); font-size: 15px; line-height: 1.7; min-height: 100vh;
    }
    header {
      border-bottom: 1px solid var(--border); padding: 28px 0 20px;
      position: sticky; top: 0; background: rgba(13,13,13,0.92);
      backdrop-filter: blur(8px); z-index: 100;
    }
    .header-inner {
      max-width: 860px; margin: 0 auto; padding: 0 24px;
      display: flex; align-items: baseline; gap: 20px; flex-wrap: wrap;
    }
    .site-name {
      font-family: var(--font-mono); font-size: 22px; font-weight: 700;
      color: var(--text); letter-spacing: -0.5px;
    }
    .site-name span { color: var(--accent-green); }
    .date-nav { margin-left: auto; display: flex; align-items: center; gap: 10px; }
    .date-arrow {
      font-family: var(--font-mono); font-size: 16px; line-height: 1;
      width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;
      border: 1px solid var(--border); border-radius: 5px; background: transparent;
      color: var(--text-muted); cursor: pointer; transition: all 0.15s;
    }
    .date-arrow:hover:not(:disabled) { border-color: var(--accent-green); color: var(--accent-green); }
    .date-arrow:disabled { opacity: 0.3; cursor: not-allowed; }
    #dateSelect {
      font-family: var(--font-mono); font-size: 13px; padding: 6px 12px;
      background: var(--bg-card); color: var(--text);
      border: 1px solid var(--border); border-radius: 5px; cursor: pointer;
      appearance: none; text-align: center; min-width: 150px;
    }
    #dateSelect:hover { border-color: var(--border-hover); }
    .today-badge {
      font-family: var(--font-mono); font-size: 9px; color: var(--accent-green);
      border: 1px solid var(--accent-green); border-radius: 3px;
      padding: 2px 6px; letter-spacing: 0.05em;
    }
    .filter-row {
      max-width: 860px; margin: 0 auto; padding: 14px 24px 0; display: flex; gap: 8px;
    }
    .filter-btn {
      font-family: var(--font-mono); font-size: 11px; padding: 4px 10px;
      border: 1px solid var(--border); border-radius: 4px; background: transparent;
      color: var(--text-muted); cursor: pointer; transition: all 0.15s;
    }
    .filter-btn:hover, .filter-btn.active { border-color: var(--accent-green); color: var(--accent-green); }
    .filter-btn[data-source="hatena"].active { border-color: var(--source-hatena); color: var(--source-hatena); }
    .filter-btn[data-source="hackernews"].active { border-color: var(--source-hn); color: var(--source-hn); }
    .filter-btn[data-source="reddit"].active { border-color: var(--source-reddit); color: var(--source-reddit); }
    main { max-width: 860px; margin: 0 auto; padding: 24px 24px 80px; }
    .stats-bar {
      display: flex; gap: 28px; margin-bottom: 28px; padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }
    .stat { display: flex; flex-direction: column; gap: 2px; }
    .stat-value {
      font-family: var(--font-mono); font-size: 24px; font-weight: 700;
      color: var(--accent-green); line-height: 1;
    }
    .stat-label {
      font-family: var(--font-mono); font-size: 10px; color: var(--text-muted);
      text-transform: uppercase; letter-spacing: 0.08em;
    }
    .articles { display: flex; flex-direction: column; gap: 2px; }
    .card {
      display: grid; grid-template-columns: 4px 1fr;
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 6px; overflow: hidden;
      transition: border-color 0.15s, background 0.15s; cursor: pointer;
    }
    .card:hover { background: var(--bg-card-hover); border-color: var(--border-hover); }
    .card-stripe { flex-shrink: 0; }
    .card[data-source="hatena"] .card-stripe { background: var(--source-hatena); }
    .card[data-source="hackernews"] .card-stripe { background: var(--source-hn); }
    .card[data-source="reddit"] .card-stripe { background: var(--source-reddit); }
    .card-body { padding: 16px 20px; }
    .card-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .source-badge {
      font-family: var(--font-mono); font-size: 10px; font-weight: 600;
      padding: 2px 7px; border-radius: 3px; letter-spacing: 0.05em; text-transform: uppercase;
    }
    .card[data-source="hatena"] .source-badge { background: rgba(0,164,222,0.15); color: var(--source-hatena); }
    .card[data-source="hackernews"] .source-badge { background: rgba(255,102,0,0.15); color: var(--source-hn); }
    .card[data-source="reddit"] .source-badge { background: rgba(255,69,0,0.15); color: var(--source-reddit); }
    .score-bar { display: flex; align-items: center; gap: 6px; flex: 1; }
    .score-track {
      height: 3px; background: var(--border); border-radius: 2px;
      flex: 1; max-width: 120px; overflow: hidden;
    }
    .score-fill { height: 100%; border-radius: 2px; background: var(--accent-green); opacity: 0.6; }
    .card[data-source="hatena"] .score-fill { background: var(--source-hatena); }
    .card[data-source="hackernews"] .score-fill { background: var(--source-hn); }
    .card[data-source="reddit"] .score-fill { background: var(--source-reddit); }
    .score-num { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); min-width: 36px; }
    .comment-count { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); }
    .card-title {
      font-size: 15px; font-weight: 600; color: var(--text); line-height: 1.45;
      margin-bottom: 10px; text-decoration: none; display: block;
    }
    .card-title:hover { color: var(--accent-green); }
    .ai-summary {
      font-size: 13px; color: #9CA3AF; line-height: 1.65; padding: 10px 12px;
      background: rgba(129,140,248,0.05); border-left: 2px solid rgba(129,140,248,0.35);
      border-radius: 0 4px 4px 0; margin-bottom: 12px;
    }
    .ai-label {
      display: inline-flex; align-items: center; gap: 4px; font-family: var(--font-mono);
      font-size: 9px; color: var(--accent-purple); letter-spacing: 0.08em;
      text-transform: uppercase; margin-bottom: 6px;
    }
    .ai-dot { width: 5px; height: 5px; background: var(--accent-purple); border-radius: 50%; }
    .tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag {
      font-family: var(--font-mono); font-size: 10px; color: var(--text-dim);
      border: 1px solid var(--text-dim); border-radius: 3px; padding: 1px 7px;
    }
    footer { border-top: 1px solid var(--border); padding: 24px; text-align: center; }
    .footer-text { font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); }
    .footer-text span { color: var(--accent-green); }
    .empty {
      display: none; text-align: center; padding: 60px 0;
      font-family: var(--font-mono); color: var(--text-muted); font-size: 13px;
    }
    @media (max-width: 600px) {
      .stats-bar { gap: 16px; }
      .stat-value { font-size: 18px; }
      .date-nav { margin-left: 0; width: 100%; margin-top: 8px; }
      #dateSelect { flex: 1; }
    }
  </style>
</head>
<body>
<header>
  <div class="header-inner">
    <div class="site-name">IT<span>//</span>ノイズ</div>
    <div class="date-nav">
      <button class="date-arrow" id="prevDate" aria-label="前の日">&lsaquo;</button>
      <select id="dateSelect"></select>
      <button class="date-arrow" id="nextDate" aria-label="次の日">&rsaquo;</button>
      <span class="today-badge" id="todayBadge">最新</span>
    </div>
  </div>
  <div class="filter-row">
    <button class="filter-btn active" data-source="all">ALL</button>
    <button class="filter-btn" data-source="hatena">はてな</button>
    <button class="filter-btn" data-source="hackernews">HN</button>
    <button class="filter-btn" data-source="reddit">Reddit</button>
  </div>
</header>
<main>
  <div class="stats-bar" id="statsBar"></div>
  <div class="articles" id="articleList"></div>
  <div class="empty" id="emptyState">該当する記事がありません</div>
</main>
<footer>
  <div class="footer-text">
    summarized by <span>Gemini</span> &nbsp;&middot;&nbsp; source: はてブ / HN / Reddit
    &nbsp;&middot;&nbsp; <span id="footerDate"></span>
  </div>
</footer>
<script id="newsData" type="application/json">{{ all_data_json | safe }}</script>
<script>
const NEWS = JSON.parse(document.getElementById('newsData').textContent);
const DATES = Object.keys(NEWS).sort().reverse();
let currentDate = DATES[0];
let currentFilter = 'all';
const sourceLabel = { hatena: 'はてな', hackernews: 'HN', reddit: 'Reddit' };

function buildDateSelector() {
  const sel = document.getElementById('dateSelect');
  sel.innerHTML = '';
  DATES.forEach(d => {
    const opt = document.createElement('option');
    opt.value = d;
    const dt = new Date(d + 'T00:00:00');
    const wd = ['日','月','火','水','木','金','土'][dt.getDay()];
    opt.textContent = d + ' (' + wd + ')';
    sel.appendChild(opt);
  });
  sel.value = currentDate;
}

function render() {
  const day = NEWS[currentDate];
  let articles = day.articles.slice().sort((a,b) => (b.score||0) - (a.score||0));
  const counts = { all: articles.length, hatena: 0, hackernews: 0, reddit: 0 };
  articles.forEach(a => { if (counts[a.source] !== undefined) counts[a.source]++; });
  document.getElementById('statsBar').innerHTML =
    '<div class="stat"><div class="stat-value">' + counts.all + '</div><div class="stat-label">articles</div></div>' +
    '<div class="stat"><div class="stat-value">' + counts.hatena + '</div><div class="stat-label">はてな</div></div>' +
    '<div class="stat"><div class="stat-value">' + counts.hackernews + '</div><div class="stat-label">HN</div></div>' +
    '<div class="stat"><div class="stat-value">' + counts.reddit + '</div><div class="stat-label">Reddit</div></div>';
  if (currentFilter !== 'all') articles = articles.filter(a => a.source === currentFilter);
  const list = document.getElementById('articleList');
  list.innerHTML = articles.map(a => {
    const width = Math.min((a.score||0) / 60, 100);
    const tags = (a.tags||[]).map(t => '<span class="tag">' + escapeHtml(t) + '</span>').join('');
    return '<article class="card" data-source="' + a.source + '" onclick="window.open(\'' + a.url + '\',\'_blank\',\'noopener\')">' +
      '<div class="card-stripe"></div><div class="card-body">' +
      '<div class="card-meta"><span class="source-badge">' + (sourceLabel[a.source]||a.source) + '</span>' +
      '<div class="score-bar"><div class="score-track"><div class="score-fill" style="width:' + width + '%"></div></div>' +
      '<span class="score-num">&#9650; ' + (a.score||0) + '</span></div>' +
      '<span class="comment-count">&#128172; ' + (a.comments||0) + '</span></div>' +
      '<a class="card-title" href="' + a.url + '" onclick="event.stopPropagation()">' + escapeHtml(a.title) + '</a>' +
      (a.summary ? '<div class="ai-summary"><div class="ai-label"><span class="ai-dot"></span>AI要約</div>' + escapeHtml(a.summary) + '</div>' : '') +
      '<div class="tags">' + tags + '</div></div></article>';
  }).join('');
  document.getElementById('emptyState').style.display = articles.length === 0 ? 'block' : 'none';
  document.getElementById('todayBadge').style.display = (currentDate === DATES[0]) ? 'inline' : 'none';
  document.getElementById('footerDate').textContent = currentDate;
  const idx = DATES.indexOf(currentDate);
  document.getElementById('nextDate').disabled = (idx <= 0);
  document.getElementById('prevDate').disabled = (idx >= DATES.length-1);
}

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

document.getElementById('dateSelect').addEventListener('change', e => { currentDate = e.target.value; render(); });
document.getElementById('prevDate').addEventListener('click', () => {
  const idx = DATES.indexOf(currentDate);
  if (idx < DATES.length-1) { currentDate = DATES[idx+1]; document.getElementById('dateSelect').value = currentDate; render(); }
});
document.getElementById('nextDate').addEventListener('click', () => {
  const idx = DATES.indexOf(currentDate);
  if (idx > 0) { currentDate = DATES[idx-1]; document.getElementById('dateSelect').value = currentDate; render(); }
});
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentFilter = btn.dataset.source;
    render();
  });
});

buildDateSelector();
render();
</script>
</body>
</html>
